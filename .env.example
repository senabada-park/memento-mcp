# Memento MCP 환경변수 샘플
# 최소 시작 경로: cp .env.example.minimal .env
# 운영형 샘플: cp .env.example .env
# 작성일: 2026-03-03
# 수정일: 2026-04-19

# ─────────────────────────────────────────
# 서버
# ─────────────────────────────────────────
PORT=57332
SESSION_TTL_MINUTES=43200       # 기본값 43200 (30일 슬라이딩, claude.ai 커넥터 호환)
LOG_DIR=./logs
# LOG_LEVEL=info                   # winston 로그 레벨 (error/warn/info/debug)

# HTTP 타임아웃 (server.js:266-268)
# KEEP_ALIVE_TIMEOUT_MS=75000      # Keep-Alive 연결 유지 시간 ms (기본 75000); proxy 뒤에서는 proxy 설정과 일치시킬 것
# HEADERS_TIMEOUT_MS=76000         # 요청 헤더 수신 완료까지 허용 시간 ms (기본 76000); KEEP_ALIVE_TIMEOUT_MS보다 크게 유지
# REQUEST_TIMEOUT_MS=0             # 전체 요청 처리 타임아웃 ms (기본 0 = 무제한); 장시간 스트리밍 시 0 권장

# ─────────────────────────────────────────
# 인증
# 설정 시 모든 요청에 Bearer 토큰 필수
# ─────────────────────────────────────────
# MEMENTO_ACCESS_KEY=your-master-key-here

# Admin UI Origin 제한 (미설정 시 모든 Origin 허용)
# ADMIN_ALLOWED_ORIGINS=https://admin.example.com,https://localhost:3000

# MCP 클라이언트 Origin 제한 (미설정 시 모든 Origin 허용)
# ALLOWED_ORIGINS=https://app.example.com

# OAuth redirect_uri 허용 prefix (미설정 시 localhost만 허용)
# OAUTH_ALLOWED_REDIRECT_URIS=https://app.example.com/callback

# 인증 비활성화 (개발 전용, MEMENTO_ACCESS_KEY 미설정 대체)
# MEMENTO_AUTH_DISABLED=false

# Rate Limiting
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=120

# API 키별 Rate Limiting
# RATE_LIMIT_PER_IP=30      # IP당 분당 요청 한도 (미인증)
# RATE_LIMIT_PER_KEY=100    # API 키당 분당 요청 한도

# ─────────────────────────────────────────
# PostgreSQL
# DATABASE_URL이 설정되지 않으면 scripts/migrate.js가 아래 개별 변수를 조합해
# postgresql://{USER}:{PASSWORD}@{HOST}:{PORT}/{DB} 형태로 DATABASE_URL을 자동 구성한다.
# DATABASE_URL을 직접 지정하면 아래 개별 변수는 무시된다.
# DATABASE_URL=postgresql://your_user:your_password@localhost:5432/your_db
# ─────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=your_db
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
# pgvector가 public이 아닌 별도 스키마에 설치된 경우 지정 (선택).
# 미설정 시 서버 시작 및 마이그레이션에서 pg_extension으로 자동 감지.
# 대부분의 환경에서는 비워두면 된다.
# PGVECTOR_SCHEMA=
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONN_TIMEOUT_MS=10000
DB_QUERY_TIMEOUT=30000

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
CACHE_ENABLED=true
CACHE_DB_TTL=300
# CACHE_SESSION_TTL=3600  # 기본값: SESSION_TTL_MINUTES와 동일

# Redis Sentinel (선택 — 고가용성 구성 시)
# REDIS_SENTINEL_ENABLED=true
# REDIS_MASTER_NAME=mymaster
# REDIS_SENTINELS=sentinel1:26379,sentinel2:26379,sentinel3:26379

# ── Embedding Provider ──────────────────────────────────────────
# 지원값: openai (기본) | gemini | ollama | localai | cloudflare | custom | transformers (v2.9.0 로컬)
EMBEDDING_PROVIDER=openai

# OpenAI (EMBEDDING_PROVIDER=openai, 기본값)
OPENAI_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small   # 기본값, 생략 가능
# EMBEDDING_DIMENSIONS=1536                 # 기본값, 생략 가능

# Google Gemini (EMBEDDING_PROVIDER=gemini)
# text-embedding-004는 2026-01-14 종료. 현재 권장: gemini-embedding-001
# EMBEDDING_PROVIDER=gemini
# GEMINI_API_KEY=AIza...
# EMBEDDING_MODEL=gemini-embedding-001      # 기본값, 생략 가능
# EMBEDDING_DIMENSIONS=3072                 # 기본값, 생략 가능
# ※ 3072차원 최초 사용 시 migration-007 실행 필요:
#   EMBEDDING_DIMENSIONS=3072 DATABASE_URL=$DATABASE_URL node scripts/post-migrate-flexible-embedding-dims.js

# Ollama 로컬 서버 (EMBEDDING_PROVIDER=ollama)
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text          # 기본값, 생략 가능
# EMBEDDING_DIMENSIONS=768                  # 기본값, 생략 가능

# LocalAI (EMBEDDING_PROVIDER=localai)
# EMBEDDING_PROVIDER=localai
# EMBEDDING_MODEL=text-embedding-ada-002    # 기본값, 생략 가능

# Cloudflare Workers AI (EMBEDDING_PROVIDER=cloudflare)
# EMBEDDING_PROVIDER=cloudflare
# CF_ACCOUNT_ID=your-cloudflare-account-id
# CF_API_TOKEN=your-cloudflare-api-token
# EMBEDDING_MODEL=@cf/baai/bge-small-en-v1.5   # 기본값, 생략 가능
# EMBEDDING_DIMENSIONS=384                       # 기본값, 생략 가능

# 커스텀 OpenAI 호환 서버 (EMBEDDING_PROVIDER=custom)
# EMBEDDING_PROVIDER=custom
# EMBEDDING_BASE_URL=http://my-server:8080/v1
# EMBEDDING_API_KEY=my-api-key
# EMBEDDING_MODEL=my-model
# EMBEDDING_DIMENSIONS=1024
# EMBEDDING_SUPPORTS_DIMS_PARAM=false       # dimensions 파라미터 지원 여부 (기본: false)

# 로컬 transformers.js (EMBEDDING_PROVIDER=transformers, v2.9.0+)
# API 키 없이 Xenova/multilingual-e5-small(384d) 또는 Xenova/bge-m3(1024d) 로컬 실행
# 주의: API 키(OPENAI_API_KEY 등)와 동시 설정 시 config 로딩에서 throw (상호 배타)
# EMBEDDING_PROVIDER=transformers
# EMBEDDING_MODEL=Xenova/multilingual-e5-small
# EMBEDDING_DIMENSIONS=384
# 또는: EMBEDDING_MODEL=Xenova/bge-m3 / EMBEDDING_DIMENSIONS=1024
# 상세: docs/embedding-local.md 참조

# ─────────────────────────────────────────
# LLM Provider Chain (v2.8.0+)
# 형태소 분리(MorphemeIndex), 자동 reflect(AutoReflect), 모순 탐지(ConflictResolver),
# 기억 평가(MemoryEvaluator), GC 요약(ConsolidatorGC)에 사용.
# LLM_PRIMARY → LLM_FALLBACKS 순차 폴백.
# ─────────────────────────────────────────

# 주 provider (기본값: gemini-cli)
LLM_PRIMARY=gemini-cli

# Fallback chain (JSON 배열). provider당 {provider, model?, apiKey?, baseUrl?} 구성.
# CLI provider(gemini-cli/codex-cli/copilot-cli)는 model/apiKey 불필요.
# API provider는 apiKey+model 필수. Ollama Cloud 예시 포함.
# LLM_FALLBACKS='[{"provider":"codex-cli"},{"provider":"copilot-cli"},{"provider":"ollama","baseUrl":"https://ollama.com","apiKey":"ollama_...","model":"glm-5.1:cloud"}]'

# 지원 provider: openai, anthropic, gemini, groq, openrouter, xai, ollama, vllm,
#                deepseek, mistral, cohere, zai, gemini-cli, codex-cli, copilot-cli

# Circuit Breaker 튜닝 (선택)
# LLM_CB_FAILURE_THRESHOLD=5       # 연속 실패 임계값 (기본 5)
# LLM_CB_OPEN_DURATION_MS=60000    # open 상태 지속 시간 ms (기본 60000)
# LLM_CB_FAILURE_WINDOW_MS=60000   # 실패 집계 윈도우 ms (기본 60000)

# Token 사용량 상한 (선택)
# LLM_TOKEN_BUDGET_INPUT=           # 입력 토큰 상한 (미설정 시 무제한)
# LLM_TOKEN_BUDGET_OUTPUT=          # 출력 토큰 상한 (미설정 시 무제한)
# LLM_TOKEN_BUDGET_WINDOW_SEC=86400 # 집계 윈도우 초 (기본 86400 = 1일)

# ─────────────────────────────────────────
# MorphemeIndex (v2.9.0 timeout 상향: 15s → 60s)
# config/memory.js morphemeIndex.geminiTimeoutMs 기본 60000
# LLM 체인 실패 시 _fallbackTokenize로 자동 우회 (fatal 아님)
# ─────────────────────────────────────────

# ─────────────────────────────────────────
# NLI 분류기 (선택 — 외부 서비스 사용 시)
# 미설정 시 in-process ONNX 모델 자동 사용
# ─────────────────────────────────────────
# NLI_SERVICE_URL=http://localhost:8080
# NLI_TIMEOUT_MS=5000

# ─────────────────────────────────────────
# 기억 시스템 유지보수
# ─────────────────────────────────────────
# CONSOLIDATE_INTERVAL_MS=3600000

# ─────────────────────────────────────────
# 기억 중복 제거 및 압축
# ─────────────────────────────────────────
# DEDUP_BATCH_SIZE=100
# DEDUP_MIN_FRAGMENTS=5
# COMPRESS_AGE_DAYS=30
# COMPRESS_MIN_GROUP=3

# ─────────────────────────────────────────
# Cross-Encoder Reranker (L4)
# ─────────────────────────────────────────
# 외부 reranker 서비스 URL (POST /rerank). 미설정 시 in-process 모드로 동작.
# RERANKER_URL=https://reranker.example.com
# RERANKER_TIMEOUT_MS=5000

# In-process 모델 (transformers.js)
# minilm  — Xenova/ms-marco-MiniLM-L-6-v2 (기본, ~80MB, 영어)
# bge-m3  — onnx-community/bge-reranker-v2-m3-ONNX (~280MB, 다국어)
# RERANKER_MODEL=minilm

# ─────────────────────────────────────────
# 압축
# ─────────────────────────────────────────
# COMPRESSION_LEVEL=6              # zlib 압축 레벨 (1-9, 기본 6)
# MIN_COMPRESS_SIZE=1024           # 압축 최소 크기 (bytes, 기본 1024)

# ─────────────────────────────────────────
# 워커
# ─────────────────────────────────────────
# WORKER_ID=                       # 클러스터 워커 ID (빈 값 = 단일 프로세스)

# ─────────────────────────────────────────
# 메모리 평가
# ─────────────────────────────────────────
# EVALUATOR_MAX_QUEUE=100          # Gemini 품질 평가 최대 큐 크기

# ─────────────────────────────────────────
# 파편 할당량 (v2.6.0+)
# ─────────────────────────────────────────
# FRAGMENT_DEFAULT_LIMIT=5000      # API 키당 기본 파편 상한

# ─────────────────────────────────────────
# OpenAPI
# ─────────────────────────────────────────
# ENABLE_OPENAPI=true              # GET /openapi.json 활성화 (master=전체, API key=권한 필터)

# ─────────────────────────────────────────
# OAuth 2.0 + DCR (v2.8.0+)
# ─────────────────────────────────────────
# 신뢰 redirect_uri 도메인 (claude.ai/chatgpt.com/copilot.microsoft.com 등 사전 내장)
# OAUTH_TRUSTED_ORIGINS=https://yourorg.com

# 미등록 client_id의 /authorize 자동 등록 허용 (기본 false, 신뢰 origin만 자동 등록)
# MCP_ALLOW_AUTO_DCR_REGISTER=false

# API 키에 바인딩되지 않은 OAuth 토큰 거부 (v2.8.5+, 기본 true)
# MCP_REJECT_NONAPIKEY_OAUTH=true

# Token TTL은 SESSION_TTL_MINUTES 기반으로 자동 계산됨
# (OAUTH_TOKEN_TTL = SESSION_TTL_MINUTES * 60초, OAUTH_REFRESH_TTL = TOKEN_TTL * 2)

# ─────────────────────────────────────────
# Symbolic Verification Layer (v2.8.0+)
# 모든 플래그는 기본 false. 활성화 시 remember/recall 응답 필드 추가.
# ─────────────────────────────────────────
# 전체 symbolic 서브시스템 마스터 킬 스위치 (false 시 비용 0)
# MEMENTO_SYMBOLIC_ENABLED=false

# Claim 추출 (Phase 0/1, MEMENTO_SYMBOLIC_ENABLED=true 전제)
# MEMENTO_SYMBOLIC_CLAIM_EXTRACTION=false

# 검색 이유 설명 (recall 응답의 explanations 필드, Phase 2)
# MEMENTO_SYMBOLIC_EXPLAIN=false

# 링크 무결성 검사 advisory (Phase 3)
# MEMENTO_SYMBOLIC_LINK_CHECK=false

# 모순 탐지 advisory (Phase 3)
# MEMENTO_SYMBOLIC_POLARITY_CONFLICT=false

# 정책 규칙 soft gating (remember 응답의 validation_warnings 필드, Phase 4)
# MEMENTO_SYMBOLIC_POLICY_RULES=false

# CBR 케이스 검색 symbolic 필터 (Phase 5)
# MEMENTO_SYMBOLIC_CBR_FILTER=false

# Proactive gate — 링크 생성 차단 (Phase 5)
# MEMENTO_SYMBOLIC_PROACTIVE_GATE=false

# Shadow mode — 규칙 평가를 기록만 하고 미적용 (Phase 1)
# MEMENTO_SYMBOLIC_SHADOW=false

# Symbolic 엔진 튜닝 (config/symbolic.js:47-49)
# MEMENTO_SYMBOLIC_RULE_VERSION=v1        # 적용할 규칙 파일 버전 (기본 v1)
# MEMENTO_SYMBOLIC_MAX_CANDIDATES=32      # 한 번에 처리할 후보 파편 상한; 클수록 정밀도 상승, 지연 증가 (기본 32)
# MEMENTO_SYMBOLIC_TIMEOUT_MS=50          # 단일 symbolic 평가 최대 허용 시간 ms; 초과 시 스킵 (기본 50)

# ─────────────────────────────────────────
# Experiential Memory (v2.5.0+, 전부 기본 false)
# ─────────────────────────────────────────
# 재통합: recall 시 링크 weight/confidence 갱신
# ENABLE_RECONSOLIDATION=false

# 확산 활성화: contextText 기반 이웃 파편 사전 부스트
# ENABLE_SPREADING_ACTIVATION=false

# 패턴 추상화
# ENABLE_PATTERN_ABSTRACTION=false

# ─────────────────────────────────────────
# Server / Reliability
# ─────────────────────────────────────────
# 단일 remember() 요청에서 quota check + INSERT를 단일 트랜잭션으로 원자화한다.
# true: BEGIN → api_keys FOR UPDATE(quota 재검증) → INSERT → COMMIT (TOCTOU 완전 차단)
# false(기본): 선제 quota check만 수행 (기존 동작 보존, 동시 요청이 드문 환경에 적합)
# MEMENTO_REMEMBER_ATOMIC=false
